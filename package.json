{
  "name": "whispers-in-the-void",
  "version": "0.1.0",
  "description": "Procedurally generated 3D space trading/combat/exploration game",
  "main": "./out/main/index.js",
  "author": "",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --dir",
    "make": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "three": "^0.169.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-vite": "^2.3.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.whispersinthevoid.game",
    "productName": "Whispers In The Void",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "allowScripts": {
    "electron@32.3.3": true,
    "esbuild@0.21.5": true
  }
}

{
  "name": "whispers-in-the-void",
  "productName": "Whispers In The Void",
  "version": "2.1.2",
  "description": "Procedurally generated 3D space trading/combat/exploration game",
  "main": "./out/main/index.js",
  "author": "Laughing In Purgatory",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --dir",
    "make": "electron-vite build && electron-builder",
    "make:all": "electron-vite build && electron-builder --mac --linux -c.mac.identity=null && electron-builder --win --x64 && electron-builder --win --arm64"
  },
  "dependencies": {
    "three": "^0.169.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-vite": "^2.3.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.whispersinthevoid.game",
    "productName": "Whispers In The Void",
    "copyright": "\u00a9 Laughing In Purgatory 2026",
    "icon": "build/icon.png",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "publisherName": "Laughing In Purgatory"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Whispers In The Void",
      "uninstallDisplayName": "Whispers In The Void",
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Game",
      "synopsis": "Whispers In The Void",
      "description": "Whispers In The Void \u2014 a procedurally generated 3D space trading, combat, and exploration game. \u00a9 Laughing In Purgatory 2026",
      "desktop": {
        "Name": "Whispers In The Void",
        "Comment": "\u00a9 Laughing In Purgatory 2026",
        "Categories": "Game;AdventureGame;"
      }
    },
    "afterSign": "scripts/afterSignAdHoc.cjs"
  },
  "allowScripts": {
    "electron@32.3.3": true,
    "esbuild@0.21.5": true
  }
}
